---
import { config } from '../config';

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background-color: rgba(10, 22, 40, 0.75); backdrop-filter: blur(16px) saturate(1.3); -webkit-backdrop-filter: blur(16px) saturate(1.3);"
>
  <!-- Prism accent line at very top -->
  <div class="prism-line"></div>

  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="flex items-center justify-between h-[72px] lg:h-20">
      <!-- Logo -->
      <a href="/" class="relative z-50 flex-shrink-0" aria-label={config.business.name}>
        <img
          src="/images/logo.svg"
          alt={config.business.name}
          class="h-10 lg:h-12 w-auto"
          width="240"
          height="48"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {config.nav.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 text-[13px] font-medium uppercase tracking-[0.08em] transition-colors duration-200 rounded-md',
                isActive
                  ? 'text-white bg-white/10'
                  : 'text-[rgba(240,247,251,0.6)] hover:text-white hover:bg-white/5',
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={`tel:${config.contact.phoneRaw}`}
          class="text-[rgba(240,247,251,0.6)] hover:text-white text-[13px] font-medium tracking-wide transition-colors duration-200"
        >
          {config.contact.phone}
        </a>
        <a href={config.cta.primary.href} class="btn-primary !min-w-0 !px-5 !py-2.5 !text-[13px]">
          Free Quote
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden relative z-50 w-10 h-10 flex items-center justify-center"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <div class="menu-icon space-y-1.5">
          <span class="block w-6 h-[2px] bg-white transition-all duration-300 origin-center"></span>
          <span class="block w-6 h-[2px] bg-white transition-all duration-300"></span>
          <span class="block w-4 h-[2px] bg-white transition-all duration-300 origin-center"></span>
        </div>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
  style="background: rgba(10, 22, 40, 0.95); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);"
>
  <nav class="flex flex-col items-center gap-6" aria-label="Mobile navigation">
    {config.nav.map((item) => (
      <a
        href={item.href}
        class="text-3xl font-bold transition-colors duration-200 text-white hover:text-[var(--color-accent)]"
        style="font-family: var(--font-family-display);"
      >
        {item.label}
      </a>
    ))}
    <div class="mt-6 flex flex-col items-center gap-4">
      <a href={config.cta.primary.href} class="btn-primary">
        {config.cta.primary.label}
      </a>
      <a
        href={`tel:${config.contact.phoneRaw}`}
        class="text-lg font-bold tracking-wide"
        style="color: var(--color-accent);"
      >
        {config.contact.phone}
      </a>
    </div>
  </nav>
</div>

<!-- Spacer for fixed header -->
<div class="h-[75px] lg:h-[83px]"></div>

<!-- Sticky Mobile CTA -->
<div
  class="lg:hidden fixed bottom-0 left-0 right-0 z-40 px-4 py-3 flex items-center justify-between gap-3"
  style="background: rgba(10, 22, 40, 0.88); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-top: 1px solid rgba(255, 255, 255, 0.1);"
>
  <a
    href={`tel:${config.contact.phoneRaw}`}
    class="flex-1 btn-primary !py-3 text-center"
  >
    <svg class="w-4 h-4 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    Call Now
  </a>
  <a
    href={config.cta.primary.href}
    class="flex-1 btn-ghost !py-3 !min-w-0 text-center"
  >
    Get Quote
  </a>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');
  let isOpen = false;

  btn?.addEventListener('click', () => {
    isOpen = !isOpen;
    btn.setAttribute('aria-expanded', String(isOpen));
    menu?.classList.toggle('opacity-0', !isOpen);
    menu?.classList.toggle('pointer-events-none', !isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';

    const spans = btn.querySelectorAll('.menu-icon span');
    if (isOpen) {
      spans[0].style.transform = 'rotate(45deg) translate(4px, 4px)';
      spans[1].style.opacity = '0';
      spans[2].style.transform = 'rotate(-45deg) translate(3px, -3px)';
      spans[2].style.width = '24px';
    } else {
      spans[0].style.transform = '';
      spans[1].style.opacity = '1';
      spans[2].style.transform = '';
      spans[2].style.width = '16px';
    }
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (isOpen) btn?.click();
    });
  });

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        if (header) {
          const scrolled = window.scrollY > 20;
          header.style.backgroundColor = scrolled
            ? 'rgba(10, 22, 40, 0.92)'
            : 'rgba(10, 22, 40, 0.75)';
          header.classList.toggle('shadow-nav', scrolled);
        }
        ticking = false;
      });
      ticking = true;
    }
  });
</script>
