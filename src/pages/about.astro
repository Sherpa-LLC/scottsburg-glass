---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
import { getEntry, render } from 'astro:content';

const { business, contact, cta } = config;
const allAreas = [...config.serviceAreas.primary, ...config.serviceAreas.secondary];

const about = await getEntry('pages', 'about');
const { heroImage, heroAlt, metaDescription } = about.data;
const { Content } = await render(about);
---

<BaseLayout
  title="About Us"
  description={metaDescription}
  schemaType="about"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'About', url: '/about' }]}
>
  <!-- HERO -->
  <section class="relative py-28 lg:py-36 overflow-hidden" style="background: var(--color-secondary);">
    {heroImage && (
      <div class="absolute inset-0">
        <img src={heroImage} alt={heroAlt || 'About us'} class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" />
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,22,40,0.82) 0%, rgba(10,22,40,0.75) 100%);"></div>
      </div>
    )}
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-4">About Us</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        {about.data.title || `About ${business.name}`}
      </h1>
      <div class="prism-line w-20 mx-auto rounded-full"></div>
    </div>
  </section>

  <!-- WBE BADGE BANNER -->
  <div class="py-6" style="background: var(--color-primary-light);">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-center gap-4 text-center sm:text-left">
      <span class="wbe-badge">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
        WBE Certified
      </span>
      <span class="text-sm font-medium" style="color: var(--color-text-light);">
        Proudly certified as a Women's Business Enterprise through 2026 by the State of Indiana
      </span>
    </div>
  </div>

  <!-- CONTENT -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary);">
        <Content />
      </div>
    </div>
  </section>

  <!-- PRECISION STATS -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg-alt);">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="section-label mb-3 reveal">By The Numbers</p>
        <h2 class="text-3xl font-bold reveal" style="font-family: var(--font-family-display);">
          Precision Craftsmanship, Proven Results
        </h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-0 rounded-xl overflow-hidden reveal" style="border: 1px solid var(--color-border); background: var(--color-surface);">
        {[
          { number: '40+', label: 'Years Serving Indiana' },
          { number: '4,000+', label: 'Windows Installed' },
          { number: '1,500+', label: 'Doors Completed' },
          { number: '5.0', label: 'Star Rating' },
        ].map((stat, i) => (
          <div
            class="p-6 lg:p-8 text-center"
            style={i > 0 ? 'border-left: 1px solid var(--color-border);' : ''}
          >
            <div class="text-3xl lg:text-4xl font-bold" style="color: var(--color-primary);">{stat.number}</div>
            <div class="text-sm mt-1" style="color: var(--color-text-muted);">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-3 reveal">Coverage Area</p>
      <h2 class="text-3xl font-bold mb-4 reveal" style="font-family: var(--font-family-display);">
        Proudly Serving {config.contact.address.city} & Beyond
      </h2>
      <div class="prism-line-thin w-16 mx-auto mb-8 reveal"></div>
      <p class="text-lg reveal" style="color: var(--color-text-muted);">
        {allAreas.join(' \u00B7 ')}
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center relative overflow-hidden" style="background: linear-gradient(135deg, var(--color-dark) 0%, #0c2d4a 50%, #0e3a5c 100%);">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 70% 30%, rgba(8,145,178,0.12) 0%, transparent 50%);"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-4" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        Ready to Work with Us?
      </h2>
      <div class="prism-line w-16 mx-auto mb-6 rounded-full"></div>
      <p class="mb-8" style="color: var(--color-text-on-dark-muted);">
        Get in touch today for a free consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>
