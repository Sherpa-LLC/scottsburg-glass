---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
import { getEntry, render } from 'astro:content';

const { business, contact, cta } = config;
const allAreas = [...config.serviceAreas.primary, ...config.serviceAreas.secondary];

const about = await getEntry('pages', 'about');
const { heroImage, heroAlt, metaDescription } = about.data;
const { Content } = await render(about);
---

<BaseLayout
  title="About Us"
  description={metaDescription}
  schemaType="about"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'About', url: '/about' }]}
>
  <!-- HERO -->
  <section class="relative py-28 lg:py-36 overflow-hidden" style={`background: var(--color-secondary);`}>
    {heroImage && (
      <div class="absolute inset-0">
        <img src={heroImage} alt={heroAlt || 'About us'} class="w-full h-full object-cover opacity-20" width="1920" height="1080" fetchpriority="high" />
      </div>
    )}
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-4">About Us</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        {about.data.title || `About ${business.name}`}
      </h1>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary);">
        <Content />
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg-alt);">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-3">Coverage Area</p>
      <h2 class="text-3xl font-bold mb-8" style="font-family: var(--font-family-display);">
        Proudly Serving {config.contact.address.city} & Beyond
      </h2>
      <p class="text-lg" style="color: var(--color-text-muted);">
        {allAreas.join(' \u00B7 ')}
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center" style={`background: var(--color-dark);`}>
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-4" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        Ready to Work with Us?
      </h2>
      <p class="mb-8" style="color: var(--color-text-on-dark-muted);">
        Get in touch today for a free consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>
