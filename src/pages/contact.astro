---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';

const { business, contact, hours } = config;
---

<BaseLayout
  title="Contact Us"
  description={`Get in touch with ${business.name}. Call ${contact.phone} or fill out our contact form for a free consultation.`}
  schemaType="contact"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact' }]}
>
  <!-- HERO -->
  <section class="py-20 lg:py-28" style={`background: var(--color-secondary);`}>
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-4">Get In Touch</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        Contact {business.name}
      </h1>
      <p class="text-lg" style="color: var(--color-text-on-dark-muted);">
        Ready to get started? Reach out today for a free consultation.
      </p>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- FORM -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold mb-6" style="font-family: var(--font-family-display);">Send Us a Message</h2>
          <form class="space-y-6" action="/contact" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium mb-2">Name *</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 rounded-md text-sm transition-colors"
                  style="border: 1px solid var(--color-border); background: var(--color-surface);"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium mb-2">Phone</label>
                <input type="tel" id="phone" name="phone"
                  class="w-full px-4 py-3 rounded-md text-sm transition-colors"
                  style="border: 1px solid var(--color-border); background: var(--color-surface);"
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium mb-2">Email *</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 rounded-md text-sm transition-colors"
                style="border: 1px solid var(--color-border); background: var(--color-surface);"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium mb-2">How can we help? *</label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-3 rounded-md text-sm transition-colors resize-none"
                style="border: 1px solid var(--color-border); background: var(--color-surface);"
              ></textarea>
            </div>
            <button type="submit" class="btn-primary">Send Message</button>
          </form>
        </div>

        <!-- INFO SIDEBAR -->
        <div class="lg:col-span-2 space-y-8">
          <div class="p-6 rounded-lg" style="background: var(--color-bg-alt);">
            <h3 class="font-bold text-lg mb-4">Call Us</h3>
            <a href={`tel:${contact.phoneRaw}`} class="text-xl font-bold" style="color: var(--color-primary);">
              {contact.phone}
            </a>
          </div>

          <div class="p-6 rounded-lg" style="background: var(--color-bg-alt);">
            <h3 class="font-bold text-lg mb-4">Email</h3>
            <a href={`mailto:${contact.email}`} class="transition-colors" style="color: var(--color-primary);">
              {contact.email}
            </a>
          </div>

          <div class="p-6 rounded-lg" style="background: var(--color-bg-alt);">
            <h3 class="font-bold text-lg mb-4">Location</h3>
            <address class="not-italic text-sm" style="color: var(--color-text-muted);">
              {contact.address.street}<br />
              {contact.address.city}, {contact.address.state} {contact.address.zip}
            </address>
          </div>

          <div class="p-6 rounded-lg" style="background: var(--color-bg-alt);">
            <h3 class="font-bold text-lg mb-4">Hours</h3>
            <dl class="space-y-1 text-sm">
              {Object.entries(hours).map(([day, h]) => (
                <div class="flex justify-between gap-4">
                  <dt class="capitalize" style="color: var(--color-text-muted);">{day}</dt>
                  <dd>{h}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
