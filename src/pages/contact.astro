---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';

const { business, contact, hours } = config;
---

<BaseLayout
  title="Contact Us"
  description={`Get in touch with ${business.name}. Call ${contact.phone} or fill out our contact form for a free consultation.`}
  schemaType="contact"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact' }]}
>
  <!-- HERO -->
  <section class="relative py-20 lg:py-28 overflow-hidden" style="background: var(--color-secondary);">
    <div class="absolute inset-0">
      <img src="/images/storefront-door-windows.jpeg" alt="Scottsburg Glass commercial glass project" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,22,40,0.82) 0%, rgba(10,22,40,0.78) 100%);"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-4">Get In Touch</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        Contact {business.name}
      </h1>
      <div class="prism-line w-20 mx-auto mb-6 rounded-full"></div>
      <p class="text-lg" style="color: var(--color-text-on-dark-muted);">
        Ready to get started? Reach out today for a free consultation.
      </p>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- FORM — Glass panel card -->
        <div class="lg:col-span-3">
          <div class="p-8 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <h2 class="text-2xl font-bold mb-2" style="font-family: var(--font-family-display);">Send Us a Message</h2>
            <div class="prism-line-thin w-12 mb-6"></div>

            <form class="space-y-6" action="/contact" method="POST">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium mb-2" style="color: var(--color-text-light);">Name *</label>
                  <input type="text" id="name" name="name" required
                    class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                    style="border: 1px solid var(--color-border); background: var(--color-bg); outline: none;"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium mb-2" style="color: var(--color-text-light);">Phone</label>
                  <input type="tel" id="phone" name="phone"
                    class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                    style="border: 1px solid var(--color-border); background: var(--color-bg); outline: none;"
                    placeholder="(812) 555-1234"
                  />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium mb-2" style="color: var(--color-text-light);">Email *</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                  style="border: 1px solid var(--color-border); background: var(--color-bg); outline: none;"
                  placeholder="you@example.com"
                />
              </div>
              <div>
                <label for="service" class="block text-sm font-medium mb-2" style="color: var(--color-text-light);">Service Needed</label>
                <select id="service" name="service"
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                  style="border: 1px solid var(--color-border); background: var(--color-bg); outline: none;"
                >
                  <option value="">Select a service...</option>
                  {config.services.map((svc) => (
                    <option value={svc.slug}>{svc.name}</option>
                  ))}
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium mb-2" style="color: var(--color-text-light);">How can we help? *</label>
                <textarea id="message" name="message" rows="5" required
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 resize-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                  style="border: 1px solid var(--color-border); background: var(--color-bg); outline: none;"
                  placeholder="Tell us about your project..."
                ></textarea>
              </div>

              <!-- Turnstile placeholder -->
              <div id="turnstile-widget" class="min-h-[65px] flex items-center">
                <noscript>
                  <p class="text-sm" style="color: var(--color-text-muted);">Please enable JavaScript for form verification.</p>
                </noscript>
              </div>

              <button type="submit" class="btn-primary w-full sm:w-auto">Send Message</button>
            </form>
          </div>
        </div>

        <!-- INFO SIDEBAR — Glass panel cards -->
        <div class="lg:col-span-2 space-y-6">
          <div class="p-6 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-primary-light);">
                <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Call Us</h3>
            </div>
            <a href={`tel:${contact.phoneRaw}`} class="text-xl font-bold" style="color: var(--color-primary);">
              {contact.phone}
            </a>
          </div>

          <div class="p-6 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-primary-light);">
                <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Email</h3>
            </div>
            <a href={`mailto:${contact.email}`} class="transition-colors" style="color: var(--color-primary);">
              {contact.email}
            </a>
          </div>

          <div class="p-6 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-primary-light);">
                <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Location</h3>
            </div>
            <address class="not-italic text-sm leading-relaxed" style="color: var(--color-text-muted);">
              {contact.address.street}<br />
              {contact.address.city}, {contact.address.state} {contact.address.zip}
            </address>
          </div>

          <div class="p-6 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-primary-light);">
                <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Hours</h3>
            </div>
            <dl class="space-y-1 text-sm">
              {Object.entries(hours).map(([day, h]) => (
                <div class="flex justify-between gap-4">
                  <dt class="capitalize" style="color: var(--color-text-muted);">{day}</dt>
                  <dd style={h === 'Closed' ? 'color: var(--color-text-muted);' : ''}>{h}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
