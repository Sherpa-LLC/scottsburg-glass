---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';
import { getCollection, render } from 'astro:content';

const { contact, cta } = config;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, author, metaDescription, heroImage, heroAlt, category, readingTime } = post.data;
const { Content } = await render(post);

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={metaDescription}
  image={heroImage}
  schemaType="blog-post"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: title, url: `/blog/${post.id}` },
  ]}
  blogPost={{ title, description: metaDescription, date, author, image: heroImage }}
>
  <!-- HERO -->
  {heroImage && (
    <section class="relative py-32 lg:py-40 overflow-hidden">
      <div class="absolute inset-0">
        <img
          src={heroImage}
          alt={heroAlt || title}
          class="w-full h-full object-cover"
          width="1920"
          height="1080"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(10,22,40,0.82), rgba(10,22,40,0.75), rgba(10,22,40,0.88));"></div>
      </div>
      <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <nav class="mb-6 text-sm" style="color: var(--color-text-on-dark-muted);">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2 opacity-40">/</span>
          <a href="/blog" class="hover:text-white transition-colors">Blog</a>
          <span class="mx-2 opacity-40">/</span>
          <span class="text-white">{title}</span>
        </nav>
        {category && (
          <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full text-white mb-4" style="background: linear-gradient(135deg, var(--color-primary), var(--color-accent));">
            {category}
          </span>
        )}
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); line-height: 1.1;">
          {title}
        </h1>
        <div class="prism-line w-16 mb-6 rounded-full"></div>
        <div class="flex items-center gap-4 text-sm" style="color: var(--color-text-on-dark-muted);">
          <span>{formattedDate}</span>
          {readingTime && (
            <>
              <span class="prism-line-thin w-3 inline-block align-middle" style="height: 1px;"></span>
              <span>{readingTime}</span>
            </>
          )}
          <span class="prism-line-thin w-3 inline-block align-middle" style="height: 1px;"></span>
          <span>By {author}</span>
        </div>
      </div>
    </section>
  )}

  <!-- ARTICLE -->
  <article class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary); --tw-prose-bold: var(--color-text);">
        <Content />
      </div>
    </div>
  </article>

  <!-- CTA -->
  <section class="py-16 text-center relative overflow-hidden" style="background: linear-gradient(135deg, var(--color-dark) 0%, #0c2d4a 50%, #0e3a5c 100%);">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 70% 30%, rgba(8,145,178,0.12) 0%, transparent 50%);"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        Ready to Get Started?
      </h2>
      <div class="prism-line w-16 mx-auto mb-6 rounded-full"></div>
      <p class="mb-8" style="color: var(--color-text-on-dark-muted);">
        Contact us today for a free consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
        <a href="/blog" class="btn-ghost">&larr; Back to Blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
