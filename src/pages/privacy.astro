---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';

const { business, contact } = config;
---

<BaseLayout
  title="Privacy Policy"
  description={`Privacy policy for ${business.name}.`}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Privacy Policy', url: '/privacy' }]}
>
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold mb-8" style="font-family: var(--font-family-display);">Privacy Policy</h1>
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary);">
        <p><strong>Last updated:</strong> {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        <p>{business.name} ("we", "us", or "our") operates the website located at {config.seo.siteUrl}. This Privacy Policy describes how we collect, use, and protect your personal information.</p>

        <h2>Information We Collect</h2>
        <p>We may collect the following types of information when you use our website:</p>
        <ul>
          <li><strong>Contact Information:</strong> Name, email address, phone number, and mailing address when you submit a form or contact us.</li>
          <li><strong>Usage Data:</strong> Information about how you interact with our website, including pages visited, time spent, and referring URLs.</li>
        </ul>

        <h2>How We Use Your Information</h2>
        <ul>
          <li>To respond to your inquiries and provide requested services</li>
          <li>To improve our website and services</li>
          <li>To send follow-up communications related to your inquiry</li>
        </ul>

        <h2>Information Sharing</h2>
        <p>We do not sell, trade, or rent your personal information to third parties. We may share information with trusted service providers who assist us in operating our website, conducting our business, or serving our customers.</p>

        <h2>Contact Us</h2>
        <p>If you have questions about this Privacy Policy, contact us at:</p>
        <ul>
          <li>Email: <a href={`mailto:${contact.email}`}>{contact.email}</a></li>
          <li>Phone: <a href={`tel:${contact.phoneRaw}`}>{contact.phone}</a></li>
          <li>Address: {contact.address.street}, {contact.address.city}, {contact.address.state} {contact.address.zip}</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
