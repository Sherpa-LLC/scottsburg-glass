---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';
import { getCollection, render } from 'astro:content';

const { contact, cta } = config;

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((svc) => ({
    params: { slug: svc.data.slug },
    props: { service: svc },
  }));
}

const { service } = Astro.props;
const { title, metaTitle, metaDescription, heroImage, heroAlt, shortDescription, faqs } = service.data;
const { Content } = await render(service);
---

<BaseLayout
  title={metaTitle || title}
  description={metaDescription}
  schemaType="service"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services' },
    { name: title, url: `/services/${service.data.slug}` },
  ]}
  serviceData={{ name: title, description: shortDescription, image: heroImage }}
  faqs={faqs}
>
  <!-- HERO -->
  <section class="relative py-28 lg:py-36 overflow-hidden" style="background: var(--color-secondary);">
    {heroImage && (
      <div class="absolute inset-0">
        <img src={heroImage} alt={heroAlt} class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" />
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,22,40,0.82) 0%, rgba(10,22,40,0.75) 100%);"></div>
      </div>
    )}
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm" style="color: var(--color-text-on-dark-muted);">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2 opacity-40">/</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span class="mx-2 opacity-40">/</span>
        <span class="text-white">{title}</span>
      </nav>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        {title}
      </h1>
      <div class="prism-line w-20 mb-6 rounded-full"></div>
      <p class="text-lg max-w-2xl" style="color: var(--color-text-on-dark-muted);">
        {shortDescription}
      </p>
      <div class="mt-8">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
      </div>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary);">
        <Content />
      </div>
    </div>
  </section>

  <!-- FAQS -->
  {faqs && faqs.length > 0 && (
    <section class="py-16 lg:py-24" style="background: var(--color-bg-alt);">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <p class="section-label mb-3 reveal">FAQ</p>
        <h2 class="text-3xl font-bold mb-4 reveal" style="font-family: var(--font-family-display);">
          Common Questions About {title}
        </h2>
        <div class="prism-line-thin w-12 mb-10 reveal"></div>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="group p-6 rounded-xl reveal" style="background: var(--color-surface); border: 1px solid var(--color-border);">
              <summary class="cursor-pointer font-bold text-lg flex items-center justify-between">
                {faq.question}
                <span class="ml-4 w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-lg group-open:rotate-45 transition-transform" style="background: var(--color-primary-light); color: var(--color-primary);">+</span>
              </summary>
              <p class="mt-4 text-sm leading-relaxed" style="color: var(--color-text-muted);">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 text-center relative overflow-hidden" style="background: linear-gradient(135deg, var(--color-dark) 0%, #0c2d4a 50%, #0e3a5c 100%);">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 70% 30%, rgba(8,145,178,0.12) 0%, transparent 50%);"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-4" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        Ready to Get Started?
      </h2>
      <div class="prism-line w-16 mx-auto mb-6 rounded-full"></div>
      <p class="mb-8" style="color: var(--color-text-on-dark-muted);">
        Contact us today for a free consultation about {title.toLowerCase()}.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>
